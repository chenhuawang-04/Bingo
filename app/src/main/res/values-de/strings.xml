    <string name="settings_pool_organize_desc">Qualitäts-First-Pool-Erstellungsparameter. Fenstergröße steuert Stapelvergleichsgröße; Parallelität und Ratenbegrenzung beeinflussen Hintergrundgeschwindigkeit und API-Belastung.</string>
    <string name="settings_retry_mode">Wiederholungsmodus</string>
    <string name="settings_retry_aggressive">Aggressiv</string>
    <string name="settings_retry_lenient">Nachsichtig</string>
    <string name="settings_retry_aggressive_desc">Aggressiv: Wiederholbare Fehler mit kurzen Verzögerungen erneut versuchen; gesamten Build bei nicht-wiederholbaren Fehlern sofort abbrechen.</string>
    <string name="settings_retry_lenient_desc">Nachsichtig: Alle Fehler erneut versuchen, erst nach Erschöpfen der Wiederholungen abbrechen. Wiederholungsintervall = Fehleranzahl × 10s (max. 2 Min.).</string>
    <string name="settings_retry_desc">Tritt ab dem nächsten Wort nach der Änderung in Kraft (konsistent mit Parallelitätseinstellung).</string>
    <string name="settings_managed_mode">Verwalteter Modus</string>
    <string name="settings_managed_mode_desc">Wenn aktiviert, setzt 10 Minuten nach Abbruch wegen Wiederholungsfehlern automatisch fort, unbegrenzt (geeignet für nächtlichen uneingeschränkten Betrieb). Kann weiterhin abgebrochen oder manuell gefüllt werden.</string>
    <string name="settings_window_size">Fenstergröße: %d</string>
    <string name="settings_window_size_desc">Anzahl der Kandidatenwörter pro KI-Stapel. Z.B. bedeutet 50: 1 Ziel + 50 Kandidaten pro Aufruf. Größer = langsamer pro Aufruf, aber breitere Abdeckung.</string>
    <string name="settings_max_concurrent">Max. Parallelität: %d</string>
    <string name="settings_max_concurrent_desc">Maximale gleichzeitige KI-Anfragen. Höher = schnellere Organisation, aber mehr Netzwerk- und API-Quotenverbrauch.</string>
    <string name="settings_rpm_limit">Ratenbegrenzung: %d/Min.</string>
    <string name="settings_rpm_limit_desc">Begrenzt KI-Anfragen pro Minute, um API-Ratenbegrenzung zu vermeiden.</string>

