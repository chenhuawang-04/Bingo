    <string name="settings_reference_source_desc">Usa el modelo rápido por defecto. Cambiar al modelo de búsqueda utiliza el ámbito \"Modelo de búsqueda\" para la obtención de referencias.</string>
    <string name="settings_pool_organize">Organización de pool</string>
    <string name="settings_pool_organize_desc">Parámetros de construcción de pool con prioridad de calidad. El tamaño de ventana controla el tamaño de comparación por lotes; la concurrencia y el límite de velocidad afectan la velocidad en segundo plano y la presión sobre la API.</string>
    <string name="settings_retry_mode">Modo de reintento</string>
    <string name="settings_retry_aggressive">Agresivo</string>
    <string name="settings_retry_lenient">Moderado</string>
    <string name="settings_retry_aggressive_desc">Agresivo: Reintenta errores reintables con pequeños retrasos; aborta toda la construcción en errores no reintables inmediatamente.</string>
    <string name="settings_retry_lenient_desc">Moderado: Reintenta todos los fallos, solo aborta tras agotar los reintentos. Intervalo de reintento = conteo de fallos × 10s (máx. 2 min).</string>
    <string name="settings_retry_desc">Toma efecto desde la siguiente palabra tras el cambio (consistente con la configuración de concurrencia).</string>
    <string name="settings_managed_mode">Modo gestionado</string>
    <string name="settings_managed_mode_desc">Al estar activado, reanuda automáticamente 10 minutos después de abortar por fallo de reintento, sin límite (adecuado para funcionamiento nocturno sin supervisión). Aún se puede cancelar o rellenar bloques manualmente.</string>
    <string name="settings_window_size">Tamaño de ventana: %d</string>
    <string name="settings_window_size_desc">Número de palabras candidatas por lote de AI. Por ejemplo, 50 significa 1 objetivo + 50 candidatas por llamada. Más grande = más lento por llamada pero mayor cobertura.</string>
    <string name="settings_max_concurrent">Máx. simultáneas: %d</string>
    <string name="settings_max_concurrent_desc">Máximo de peticiones AI simultáneas. Mayor = organización más rápida, pero más uso de red y cuota de API.</string>
    <string name="settings_rpm_limit">Límite de velocidad: %d/min</string>
    <string name="settings_rpm_limit_desc">Limita las peticiones AI por minuto para evitar el límite de velocidad de la API.</string>

